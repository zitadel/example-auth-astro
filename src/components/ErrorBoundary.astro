---
/**
 * Error Boundary Component
 *
 * In Astro, error handling is performed at the page level rather than within
 * the component tree. This component provides a structural wrapper with a slot
 * for content, matching the interface of error boundary components in other
 * frameworks for parity. Runtime component-level error catching requires
 * client-side JavaScript or a client-side framework island.
 *
 * For SSR error handling, Astro uses `src/pages/error.astro` as a catch-all
 * error page and `src/pages/404.astro` for not-found errors.
 *
 * ## Features
 * - Wraps child content in a structural container
 * - Integrates with Astro's native error page mechanism
 * - Supports custom fallback content via the `fallback` slot
 *
 * ## Usage
 *
 * ```astro
 * // Wrap any content that might encounter errors
 * <ErrorBoundary>
 *   <SomeComponentThatMightFail />
 * </ErrorBoundary>
 *
 * // With custom fallback (shown if the default slot errors)
 * <ErrorBoundary>
 *   <Component />
 *   <div slot="fallback">Custom error message</div>
 * </ErrorBoundary>
 * ```
 */

// The `Props` interface declares an optional `showDetails` prop callers can
// pass, but Astro doesn't have runtime component-level error catching, so
// the value isn't read inside this wrapper. The prop is forward-compatible:
// it'll be consumed once Astro adds a hook for it.
interface Props {
  showDetails?: boolean;
}
---

<slot />
